+/// Parses GeoTIFF spatial transform metadata by reading raw TIFF IFD entries.
+/// This bypasses the tiff crate's tag API which may not handle GeoTIFF-specific
+/// DOUBLE-typed tags (33550, 33922) correctly in all versions.
+fn parse_geotiff_transform(
+    _decoder: &mut TiffDecoder<std::fs::File>,
+    img_width: u32,
+    img_height: u32,
+) -> Result<GeoTiffInfo, Box<dyn std::error::Error>> {
+    // Re-open the file to parse raw IFD tags independently of the tiff decoder
+    // This is necessary because the tiff crate may not expose custom GeoTIFF tags
+    let raw_tags = parse_raw_geotiff_tags()?;
+
+    let pixel_scale = raw_tags.pixel_scale;
+    let tiepoint = raw_tags.tiepoint;
+
+    let (origin_x, origin_y, pixel_size_x, pixel_size_y) = if tiepoint.len() >= 6
+        && pixel_scale.len() >= 2
+    {
+        let ox = tiepoint[3] - tiepoint[0] * pixel_scale[0];
+        let oy = tiepoint[4] + tiepoint[1] * pixel_scale[1];
+        (ox, oy, pixel_scale[0], pixel_scale[1])
+    } else if raw_tags.transform.len() >= 8 {
+        (
+            raw_tags.transform[3],
+            raw_tags.transform[7],
+            raw_tags.transform[0].abs(),
+            raw_tags.transform[5].abs(),
+        )
+    } else {
+        return Err("GeoTIFF has no spatial reference tags (33922/33550 or 34264)".into());
+    };
+
+    let is_bng = raw_tags.is_bng
+        || (origin_x > 0.0
+            && origin_x < 700_000.0
+            && origin_y > 0.0
+            && origin_y < 1_300_000.0);
+
+    Ok(GeoTiffInfo {
+        width: img_width,
+        height: img_height,
+        origin_x,
+        origin_y,
+        pixel_size_x,
+        pixel_size_y,
+        is_bng,
+    })
+}
+
+/// Raw GeoTIFF tag values parsed directly from the TIFF IFD.
+struct RawGeoTiffTags {
+    pixel_scale: Vec<f64>,
+    tiepoint: Vec<f64>,
+    transform: Vec<f64>,
+    is_bng: bool,
+}
+
+// We need this path reference for reopening the file during tag parsing.
+// The path is stored as a thread-local to pass between the public API and the raw parser.
+use std::cell::RefCell;
+thread_local! {
+    static GEOTIFF_PATH: RefCell<Option<PathBuf>> = const { RefCell::new(None) };
+}
+
+/// Parses GeoTIFF tags directly from the TIFF binary, bypassing the tiff crate.
+fn parse_raw_geotiff_tags() -> Result<RawGeoTiffTags, Box<dyn std::error::Error>> {
+    let path = GEOTIFF_PATH.with(|p| p.borrow().clone())
+        .ok_or("GeoTIFF path not set")?;
+
+    let data = std::fs::read(&path)?;
+    let bo_le = data.len() >= 2 && data[0] == b'I' && data[1] == b'I';
+
+    let read_u16 = |offset: usize| -> u16 {
+        if bo_le {
+            u16::from_le_bytes([data[offset], data[offset + 1]])
+        } else {
+            u16::from_be_bytes([data[offset], data[offset + 1]])
+        }
+    };
+    let read_u32 = |offset: usize| -> u32 {
+        if bo_le {
+            u32::from_le_bytes([data[offset], data[offset + 1], data[offset + 2], data[offset + 3]])
+        } else {
+            u32::from_be_bytes([data[offset], data[offset + 1], data[offset + 2], data[offset + 3]])
+        }
+    };
+    let read_f64 = |offset: usize| -> f64 {
+        let bytes: [u8; 8] = data[offset..offset + 8].try_into().unwrap();
+        if bo_le { f64::from_le_bytes(bytes) } else { f64::from_be_bytes(bytes) }
+    };
+
+    let ifd_offset = read_u32(4) as usize;
+    let n_entries = read_u16(ifd_offset) as usize;
+
+    let mut pixel_scale = Vec::new();
+    let mut tiepoint = Vec::new();
+    let mut transform = Vec::new();
+    let mut geokeys = Vec::new();
+
+    for i in 0..n_entries {
+        let entry_offset = ifd_offset + 2 + i * 12;
+        let tag = read_u16(entry_offset);
+        let dtype = read_u16(entry_offset + 2);
+        let count = read_u32(entry_offset + 4) as usize;
+        let value_offset_raw = entry_offset + 8;
+
+        // DOUBLE type = 12, each value is 8 bytes
+        // SHORT type = 3, each value is 2 bytes
+        let type_size: usize = match dtype {
+            3 => 2,  // SHORT
+            12 => 8, // DOUBLE
+            _ => 0,
+        };
+
+        if type_size == 0 {
+            continue;
+        }
+
+        let total_size = type_size * count;
+        let data_offset = if total_size > 4 {
+            read_u32(value_offset_raw) as usize
+        } else {
+            value_offset_raw
+        };
+
+        match tag {
+            33550 if dtype == 12 => {
+                // ModelPixelScaleTag
+                for j in 0..count {
+                    pixel_scale.push(read_f64(data_offset + j * 8));
+                }
+            }
+            33922 if dtype == 12 => {
+                // ModelTiepointTag
+                for j in 0..count {
+                    tiepoint.push(read_f64(data_offset + j * 8));
+                }
+            }
+            34264 if dtype == 12 => {
+                // ModelTransformationTag
+                for j in 0..count {
+                    transform.push(read_f64(data_offset + j * 8));
+                }
+            }
+            34735 if dtype == 3 => {
+                // GeoKeyDirectoryTag
+                for j in 0..count {
+                    geokeys.push(read_u16(data_offset + j * 2));
+                }
+            }
+            _ => {}
+        }
+    }
+
+    // Check for EPSG:27700 in GeoKeys
+    let is_bng = geokeys.chunks(4).any(|chunk| {
+        chunk.len() == 4 && chunk[0] == 3072 && chunk[3] == 27700
+    });
+
+    Ok(RawGeoTiffTags {
+        pixel_scale,
+        tiepoint,
+        transform,
+        is_bng,
+    })
+}
+
+/// Reads the first band of a GeoTIFF as f64 elevation values.
+fn read_elevation_band(
+    decoder: &mut TiffDecoder<std::fs::File>,
+    info: &GeoTiffInfo,
+) -> Result<Vec<f64>, Box<dyn std::error::Error>> {
+    use tiff::decoder::DecodingResult;
+
+    let result = decoder.read_image()?;
+    let total_pixels = info.width as usize * info.height as usize;
+
+    let values: Vec<f64> = match result {
+        DecodingResult::F32(data) => data.iter().take(total_pixels).map(|&v| v as f64).collect(),
+        DecodingResult::F64(data) => data.into_iter().take(total_pixels).collect(),
+        DecodingResult::I16(data) => data.iter().take(total_pixels).map(|&v| v as f64).collect(),
+        DecodingResult::U16(data) => data.iter().take(total_pixels).map(|&v| v as f64).collect(),
+        DecodingResult::I32(data) => data.iter().take(total_pixels).map(|&v| v as f64).collect(),
+        DecodingResult::U32(data) => data.iter().take(total_pixels).map(|&v| v as f64).collect(),
+        DecodingResult::U8(data) => data.iter().take(total_pixels).map(|&v| v as f64).collect(),
+        _ => return Err("Unsupported GeoTIFF pixel type".into()),
+    };
+
+    println!("  Read {} elevation values from GeoTIFF", values.len());
+    Ok(values)
+}

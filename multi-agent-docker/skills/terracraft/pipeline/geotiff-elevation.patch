+/// Metadata extracted from a GeoTIFF file describing its spatial extent and resolution.
+struct GeoTiffInfo {
+    /// Width in pixels
+    width: u32,
+    /// Height in pixels
+    height: u32,
+    /// Top-left X coordinate (easting or longitude)
+    origin_x: f64,
+    /// Top-left Y coordinate (northing or latitude)
+    origin_y: f64,
+    /// Pixel width in coordinate units (positive)
+    pixel_size_x: f64,
+    /// Pixel height in coordinate units (positive, stored as abs value)
+    pixel_size_y: f64,
+    /// True if coordinates are in British National Grid (EPSG:27700)
+    is_bng: bool,
+}
+
+/// Reads elevation data from a GeoTIFF file, resampling onto the Minecraft grid.
+///
+/// Supports Float32, Float64, Int16, and UInt16 pixel types in either
+/// EPSG:4326 (WGS84 lat/lon) or EPSG:27700 (British National Grid).
+/// Falls back to BNG detection heuristic when GeoKey metadata is absent.
+pub fn fetch_elevation_from_geotiff(
+    path: &Path,
+    bbox: &LLBBox,
+    scale: f64,
+    ground_level: i32,
+) -> Result<ElevationData, Box<dyn std::error::Error>> {
+    let (base_scale_z, base_scale_x) = geo_distance(bbox.min(), bbox.max());
+    let scale_factor_z: f64 = base_scale_z.floor() * scale;
+    let scale_factor_x: f64 = base_scale_x.floor() * scale;
+    let grid_width: usize = scale_factor_x as usize;
+    let grid_height: usize = scale_factor_z as usize;
+
+    println!("Reading elevation from GeoTIFF: {}", path.display());
+
+    // Store path for raw tag parser (thread-local, used by parse_raw_geotiff_tags)
+    GEOTIFF_PATH.with(|p| *p.borrow_mut() = Some(path.to_path_buf()));
+
+    let file = std::fs::File::open(path)?;
+    let mut decoder = TiffDecoder::new(file)?;
+
+    let (img_width, img_height) = decoder.dimensions()?;
+
+    // Parse geospatial transform from GeoTIFF tags
+    let geo_info = parse_geotiff_transform(&mut decoder, img_width, img_height)?;
+
+    println!(
+        "  GeoTIFF: {}x{} pixels, origin ({:.1}, {:.1}), pixel size ({:.2}, {:.2}){}",
+        geo_info.width,
+        geo_info.height,
+        geo_info.origin_x,
+        geo_info.origin_y,
+        geo_info.pixel_size_x,
+        geo_info.pixel_size_y,
+        if geo_info.is_bng { " [BNG]" } else { " [WGS84]" }
+    );
+
+    // Read elevation values into a flat Vec<f64>
+    let elevation_values = read_elevation_band(&mut decoder, &geo_info)?;
+
+    // Build the height grid by sampling the GeoTIFF at each Minecraft grid cell
+    let mut height_grid: Vec<Vec<f64>> = vec![vec![f64::NAN; grid_width]; grid_height];
+
+    for gy in 0..grid_height {
+        for gx in 0..grid_width {
+            // Map grid cell to geographic coordinates within the bbox
+            let rel_x = (gx as f64 + 0.5) / grid_width as f64;
+            let rel_y = (gy as f64 + 0.5) / grid_height as f64;
+
+            let lng = bbox.min().lng() + rel_x * (bbox.max().lng() - bbox.min().lng());
+            // Y is inverted: grid row 0 = max lat (north)
+            let lat = bbox.max().lat() - rel_y * (bbox.max().lat() - bbox.min().lat());
+
+            // Convert geographic coords to pixel coords in the GeoTIFF
+            let (px, py) = if geo_info.is_bng {
+                // Convert WGS84 lat/lng to approximate BNG eastings/northings
+                let (easting, northing) = wgs84_to_bng_approx(lat, lng);
+                let px = (easting - geo_info.origin_x) / geo_info.pixel_size_x;
+                let py = (geo_info.origin_y - northing) / geo_info.pixel_size_y;
+                (px, py)
+            } else {
+                let px = (lng - geo_info.origin_x) / geo_info.pixel_size_x;
+                let py = (geo_info.origin_y - lat) / geo_info.pixel_size_y;
+                (px, py)
+            };
+
+            // Bilinear interpolation
+            let ix = px.floor() as i64;
+            let iy = py.floor() as i64;
+            let fx = px - px.floor();
+            let fy = py - py.floor();
+
+            if ix >= 0
+                && iy >= 0
+                && (ix + 1) < geo_info.width as i64
+                && (iy + 1) < geo_info.height as i64
+            {
+                let idx = |r: i64, c: i64| -> usize {
+                    (r as usize) * (geo_info.width as usize) + (c as usize)
+                };
+                let v00 = elevation_values[idx(iy, ix)];
+                let v10 = elevation_values[idx(iy, ix + 1)];
+                let v01 = elevation_values[idx(iy + 1, ix)];
+                let v11 = elevation_values[idx(iy + 1, ix + 1)];
+
+                // Skip nodata values (commonly -9999 or very negative)
+                if v00 > -1000.0 && v10 > -1000.0 && v01 > -1000.0 && v11 > -1000.0 {
+                    let h = v00 * (1.0 - fx) * (1.0 - fy)
+                        + v10 * fx * (1.0 - fy)
+                        + v01 * (1.0 - fx) * fy
+                        + v11 * fx * fy;
+                    height_grid[gy][gx] = h;
+                }
+            }
+        }
+    }
+
+    println!(
+        "  Sampled {}x{} grid from GeoTIFF",
+        grid_width, grid_height
+    );
+    emit_gui_progress_update(15.0, "Processing elevation from GeoTIFF...");
+
+    // Reuse the standard post-processing pipeline
+    fill_nan_values(&mut height_grid);
+    filter_elevation_outliers(&mut height_grid);
+
+    let grid_size: f64 = (grid_width.min(grid_height) as f64).max(1.0);
+    // Use a smaller sigma for custom DEMs since they are already high quality
+    let sigma: f64 = 2.0 * (grid_size / 100.0).sqrt();
+    let blurred_heights: Vec<Vec<f64>> = apply_gaussian_blur(&height_grid, sigma);
+    drop(height_grid);
+
+    // Scale to Minecraft Y coordinates (reuse existing logic)
+    let (min_height, max_height) = blurred_heights
+        .par_iter()
+        .map(|row| {
+            let mut local_min = f64::MAX;
+            let mut local_max = f64::MIN;
+            for &h in row {
+                local_min = local_min.min(h);
+                local_max = local_max.max(h);
+            }
+            (local_min, local_max)
+        })
+        .reduce(
+            || (f64::MAX, f64::MIN),
+            |(min1, max1), (min2, max2)| (min1.min(min2), max1.max(max2)),
+        );
+
+    let height_range: f64 = max_height - min_height;
+    let ideal_scaled_range: f64 = height_range * scale;
+    const TERRAIN_HEIGHT_BUFFER: i32 = 15;
+    let available_y_range: f64 = (MAX_Y - TERRAIN_HEIGHT_BUFFER - ground_level) as f64;
+
+    let scaled_range: f64 = if ideal_scaled_range <= available_y_range {
+        eprintln!(
+            "Realistic elevation: {:.1}m range fits in {} available blocks",
+            height_range, available_y_range as i32
+        );
+        ideal_scaled_range
+    } else {
+        let compression_factor: f64 = available_y_range / height_range;
+        let compressed_range: f64 = height_range * compression_factor;
+        eprintln!(
+            "Elevation compressed: {:.1}m range -> {:.0} blocks ({:.2}:1 ratio)",
+            height_range,
+            compressed_range,
+            height_range / compressed_range
+        );
+        compressed_range
+    };
+
+    let mc_heights: Vec<Vec<i32>> = blurred_heights
+        .par_iter()
+        .map(|row| {
+            row.iter()
+                .map(|&h| {
+                    let relative_height: f64 = if height_range > 0.0 {
+                        (h - min_height) / height_range
+                    } else {
+                        0.0
+                    };
+                    let scaled_height: f64 = relative_height * scaled_range;
+                    ((ground_level as f64 + scaled_height).round() as i32)
+                        .clamp(ground_level, MAX_Y - TERRAIN_HEIGHT_BUFFER)
+                })
+                .collect()
+        })
+        .collect();
+
+    Ok(ElevationData {
+        heights: mc_heights,
+        width: grid_width,
+        height: grid_height,
+    })
+}

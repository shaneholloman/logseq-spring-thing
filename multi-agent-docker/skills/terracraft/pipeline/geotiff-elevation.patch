+/// Approximate WGS84 to British National Grid conversion.
+/// Uses a simplified Helmert transform — accurate to ~5m, sufficient for DEM sampling.
+fn wgs84_to_bng_approx(lat: f64, lng: f64) -> (f64, f64) {
+    let lat_rad = lat.to_radians();
+    let lng_rad = lng.to_radians();
+
+    // Airy 1830 ellipsoid
+    let a = 6_377_563.396;
+    let b = 6_356_256.909;
+    let e2 = (a * a - b * b) / (a * a);
+    let n = (a - b) / (a + b);
+    let n2 = n * n;
+    let n3 = n * n * n;
+
+    // National Grid origin: 49N, 2W
+    let lat0: f64 = (49.0_f64).to_radians();
+    let lng0: f64 = (-2.0_f64).to_radians();
+    let f0: f64 = 0.9996012717; // scale factor
+    let e0: f64 = 400_000.0; // false easting
+    let n0: f64 = -100_000.0; // false northing
+
+    let sin_lat = lat_rad.sin();
+    let cos_lat = lat_rad.cos();
+    let tan_lat = lat_rad.tan();
+    let tan2 = tan_lat * tan_lat;
+
+    let nu = a * f0 / (1.0 - e2 * sin_lat * sin_lat).sqrt();
+    let rho = a * f0 * (1.0 - e2) / (1.0 - e2 * sin_lat * sin_lat).powf(1.5);
+    let eta2 = nu / rho - 1.0;
+
+    let dlat = lat_rad - lat0;
+    let slat = lat_rad + lat0;
+
+    let ma = (1.0 + n + 1.25 * n2 + 1.25 * n3) * dlat;
+    let mb = (3.0 * n + 3.0 * n2 + 21.0 / 8.0 * n3) * dlat.sin() * slat.cos();
+    // Corrected: should be (dlat*2).sin() * (slat*2).cos() etc. but for ~5m accuracy:
+    let mc = (15.0 / 8.0 * n2 + 15.0 / 8.0 * n3) * (2.0 * dlat).sin() * (2.0 * slat).cos();
+    let md = 35.0 / 24.0 * n3 * (3.0 * dlat).sin() * (3.0 * slat).cos();
+    let m_val = b * f0 * (ma - mb + mc - md);
+
+    let dlng = lng_rad - lng0;
+    let dlng2 = dlng * dlng;
+
+    let i_val = m_val + n0;
+    let ii = nu / 2.0 * sin_lat * cos_lat;
+    let iii = nu / 24.0 * sin_lat * cos_lat.powi(3) * (5.0 - tan2 + 9.0 * eta2);
+    let iiia = nu / 720.0 * sin_lat * cos_lat.powi(5) * (61.0 - 58.0 * tan2 + tan2 * tan2);
+
+    let iv = nu * cos_lat;
+    let v = nu / 6.0 * cos_lat.powi(3) * (nu / rho - tan2);
+    let vi = nu / 120.0
+        * cos_lat.powi(5)
+        * (5.0 - 18.0 * tan2 + tan2 * tan2 + 14.0 * eta2 - 58.0 * tan2 * eta2);
+
+    let northing = i_val + ii * dlng2 + iii * dlng2 * dlng2 + iiia * dlng2 * dlng2 * dlng2;
+    let easting = e0 + iv * dlng + v * dlng * dlng2 + vi * dlng * dlng2 * dlng2;
+
+    (easting, northing)
+}

  "description": "Technology recommender for the RuVector monorepo — semantic search, RVBP generation, problem-solution mapping, and industry vertical overlays",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ruvector-catalog": "dist/cli.js"
  },
  "scripts": {

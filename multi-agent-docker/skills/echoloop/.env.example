# ── Required: pick one LLM provider ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# ECHOLOOP_LLM_PROVIDER=openai

# ── Optional: audio devices ──────────────────────────────────────────
# ECHOLOOP_SYSTEM_DEVICE=CABLE Output
# ECHOLOOP_MIC_DEVICE=

# ── Optional: transcription backend ──────────────────────────────────
# ECHOLOOP_TRANSCRIBER=local
# ECHOLOOP_WHISPER_MODEL=base.en
# ECHOLOOP_WHISPER_DEVICE=cpu
# ECHOLOOP_WHISPER_COMPUTE=int8
# ECHOLOOP_LANGUAGE=en
# DEEPGRAM_API_KEY=

# ── Optional: LLM tuning ────────────────────────────────────────────
# ECHOLOOP_LLM_TEMPERATURE=0.4
# ECHOLOOP_PUSH_INTERVAL=35
# ECHOLOOP_SILENCE_TRIGGER=4.0
# ECHOLOOP_MEETING_CONTEXT=Sales call with VP Eng at Acme Corp

# ── Optional: session logging ────────────────────────────────────────
# ECHOLOOP_LOG_DIR=~/.echoloop/logs

# ── Optional: UI ─────────────────────────────────────────────────────
# ECHOLOOP_OPACITY=0.88
# ECHOLOOP_ENERGY_THRESHOLD=0.005

# =============================================================================
# Skills Environment Configuration
# Copy to /home/devuser/.claude/skills/.env and configure
# =============================================================================

# --- API Keys (Required for respective skills) ---
PERPLEXITY_API_KEY=           # perplexity, perplexity-research skills
SALAD_API_KEY=                # comfyui distributed compute (Salad Cloud)
SALAD_ORG_NAME=               # comfyui Salad Cloud organization

# --- Service Ports (Container Internal) ---
COMFYUI_URL=http://localhost:8188
BLENDER_PORT=9876
QGIS_PORT=9877
PBR_PORT=9878
PLAYWRIGHT_PROXY_PORT=9879
ZAI_URL=http://localhost:9600/chat
MANAGEMENT_API_URL=http://localhost:9090

# --- LLM Configuration ---
ANTHROPIC_API_KEY=            # Direct Claude access (set in .env at container level)
ANTHROPIC_BASE_URL=           # Override for Z.AI: http://localhost:9600
OPENAI_API_KEY=               # OpenAI fallback
GOOGLE_API_KEY=               # Gemini access (gemini-user)

# --- Paths ---
COMFYUI_OUTPUT_DIR=/home/devuser/ComfyUI/output
DOCKER_SOCKET_PATH=/var/run/docker.sock
VISIONFLOW_COMPOSE_PATH=/path/to/visionflow/docker-compose.yml

# --- Display Configuration ---
DISPLAY=:1
CHROMIUM_PATH=/usr/bin/chromium
PLAYWRIGHT_HEADLESS=false
SCREENSHOT_DIR=/tmp/playwright-screenshots
PLAYWRIGHT_TIMEOUT=30000
VIEWPORT_WIDTH=1920
VIEWPORT_HEIGHT=1080

# --- ImageMagick ---
IMAGEMAGICK_TIMEOUT=300

# --- QGIS ---
QGIS_HOST=localhost
QGIS_TIMEOUT=60

# --- Web Summary ---
ZAI_TIMEOUT=60

# --- VisionFlow MCP Integration ---
# VisionFlow connects to MCP skills via TCP on port 9500
# Skills expose capabilities via MCP resources for discovery
MCP_TCP_PORT=9500
VISIONFLOW_HOST=multi-agent-container

# --- LinkedIn MCP (browser-based auth, no API key — profile stored at ~/.linkedin-mcp/) ---
LINKEDIN_TIMEOUT=5000

# --- Reddit MCP (anonymous mode works without keys, app-only needs CLIENT_ID+SECRET) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# --- Defense MCP (Linux security - safe defaults) ---
DEFENSE_MCP_DRY_RUN=true
DEFENSE_MCP_REQUIRE_CONFIRMATION=true
DEFENSE_MCP_ALLOWED_DIRS=/tmp,/home,/var/log
DEFENSE_MCP_LOG_LEVEL=info
# Nano Banana Art Skill (claude-art-skill)
GOOGLE_API_KEY=
OPENROUTER_KEY=
REMOVEBG_API_KEY=

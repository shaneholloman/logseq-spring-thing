{
  "version": "4.1.0",
  "memory": {
    "backend": "postgres",
    "pgConnInfo": "${RUVECTOR_PG_CONNINFO}",
    "postgres": {
      "host": "ruvector-postgres",
      "port": 5432,
      "database": "ruvector",
      "user": "ruvector",
      "password": "ruvector",
      "ssl": false,
      "connectionTimeout": 10000,
      "maxConnections": 20
    },
    "embeddingsProvider": "ruvector-native",
    "fallbackEmbeddings": "xenova-onnx",
    "fallback": "sqlite",
    "enableHNSW": true,
    "cacheSize": 256,
    "useExternal": true
  },
  "swarm": {
    "topology": "hierarchical-mesh",
    "maxAgents": 15,
    "strategy": "specialized"
  },
  "neural": {
    "enabled": true,
    "backend": "postgres",
    "sona": {
      "enabled": true,
      "nativeBinding": true,
      "adaptiveEmbeddings": true,
      "learnFromOutcome": true
    }
  },
  "reasoningBank": {
    "enabled": true,
    "verdictJudge": true,
    "postTaskHook": true,
    "distillMemories": true,
    "consolidation": true,
    "heuristicFallback": true
  },
  "features": {
    "enable_post_task_hook": true,
    "enable_verdict_judge": true,
    "enable_adaptive_embeddings": true,
    "enable_pattern_extraction": true
  }
}

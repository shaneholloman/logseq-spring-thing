    classDef validate fill:#1A0A2A,stroke:#8B5CF6,stroke-width:2px,color:#E8D5FC
    classDef integrate fill:#0A1A2A,stroke:#00D4FF,stroke-width:2px,color:#D5F4FC
    classDef amplify fill:#0A2A1A,stroke:#10B981,stroke-width:2px,color:#D5FCE8

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dreamlab.ai/schemas/fixtures/_common-meta.schema.json",
  "title": "Common _meta block for all DreamLab cross-substrate fixtures",
  "type": "object",
  "required": ["source", "commit", "upstream_path", "fetched_at", "license", "spec", "schema"],
  "additionalProperties": true,
  "properties": {
    "source": {"type": "string", "description": "URL of upstream repo OR 'DreamLab-internal'"},
    "commit": {"type": "string", "description": "40-char hex commit SHA OR 'in-tree'"},
    "upstream_path": {"type": "string"},
    "fetched_at": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "license": {"type": "string"},
    "spec": {"type": "string"},
    "vector_count": {"type": "integer", "minimum": 3},
    "kind_breakdown": {"type": "object"},
    "schema": {"type": "string", "description": "Free-form description of the per-vector field shape"}
  }
}

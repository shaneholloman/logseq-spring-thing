{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dreamlab.ai/schemas/fixtures/did-doc-conformance.schema.json",
  "title": "DID Document conformance fixture (ADR-074 D2)",
  "type": "object",
  "required": ["_meta", "vectors"],
  "additionalProperties": false,
  "properties": {
    "_meta": {"$ref": "_common-meta.schema.json"},
    "vectors": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["case", "tier", "document", "valid"],
        "properties": {
          "case": {"type": "string"},
          "tier": {"enum": [1, 3]},
          "document": {
            "type": "object",
            "required": ["@context", "id", "verificationMethod"],
            "properties": {
              "@context": {"type": "array", "items": {"type": "string"}},
              "id": {"type": "string"},
              "alsoKnownAs": {"type": "array", "items": {"type": "string"}},
              "verificationMethod": {"type": "array"},
              "authentication": {"type": "array"},
              "assertionMethod": {"type": "array"},
              "service": {"type": "array"}
            }
          },
          "valid": {"type": "boolean"},
          "violation": {"type": "string"},
          "note": {"type": "string"}
        }
      }
    }
  }
}

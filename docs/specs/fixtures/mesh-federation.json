    {
      "case": "loop-avoidance-x-mesh-from-peer",
      "scenario": "loop-avoidance",
      "input": {
        "event": {
          "kind": 14,
          "tags": [
            ["p", "..."],
            ["x-mesh-from", "relay-a"]
          ],
          "id": "abc123"
        },
        "local_relay_id": "relay-b",
        "peer_relays": ["wss://relay-a.example.com/", "wss://relay-c.example.com/"]
      },
      "expected_action": {
        "fan_out_to": ["wss://relay-c.example.com/"],
        "reason": "do not fan back to relay-a (x-mesh-from origin); fan-out to relay-c only"
      },
      "valid": true,
      "note": "Federation worker tracks x-mesh-from tags and excludes the source peer from fan-out targets."
    },
    {
      "case": "lru-dedup-prevents-republish",
      "scenario": "lru-dedup",
      "input": {
        "sequence": [
          {"event_id": "abc123", "from_peer": "relay-a"},
          {"event_id": "abc123", "from_peer": "relay-b"}
        ],
        "lru_size": 4096,
        "lru_ttl_seconds": 600
      },
      "expected_action": {
        "first_event": {"fan_out": true, "lru_record_id": "abc123"},
        "second_event": {"fan_out": false, "reason": "id abc123 already in LRU within TTL window"}
      },
      "valid": true,
      "note": "Per ADR-073 D9.2: LRU dedup is per-peer (otherwise A→B and A→C race). Same id received from second peer within TTL → no re-publish."
    },

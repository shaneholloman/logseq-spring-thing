{
  "_comment_file": "VisionFlow canonical JSON-LD 1.1 context, version 1.",
  "_comment_owner": "docs/data-sprint/ADR-D01-canonical-source-schema.md is authoritative.",
  "_comment_url_reserved": "https://narrativegoldmine.com/context/v1.jsonld",
  "_comment_in_repo_path": "docs/data-sprint/context-v1.jsonld",
  "_comment_schema_version": 1,
  "_comment_jsonld_version": "1.1",
  "_comment_owl_profile": "OWL 2 EL (whelk-rs compatible)",
  "_comment_change_policy": "Breaking changes mint a v2 file. No silent edits to v1.",

  "@context": {
    "@version": 1.1,

    "_comment_default_vocab": "Unprefixed terms expand to the vc: (VisionFlow) namespace. Anything not in the table below is treated as a VisionFlow extension predicate.",
    "@vocab": "urn:visionflow:owl:property:",

    "_comment_prefixes": "VisionFlow prefixes — content addressing and DID identity.",
    "vf":       "urn:visionflow:",
    "vc":       "urn:visionflow:owl:property:",
    "vcclass":  "urn:visionflow:owl:class:",
    "vcaxiom":  "urn:visionflow:axiom:",
    "vcpage":   "urn:visionflow:page:",
    "vcagent":  "urn:visionflow:agent:",
    "vcgraph":  "urn:visionflow:graph:",
    "did":      "did:",

    "_comment_w3c_vocabs": "W3C standard vocabularies re-exported by VisionFlow. The canonical schema asserts that any predicate from this set IS that predicate — no aliasing into a private namespace.",
    "rdf":      "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs":     "http://www.w3.org/2000/01/rdf-schema#",
    "owl":      "http://www.w3.org/2002/07/owl#",
    "skos":     "http://www.w3.org/2004/02/skos/core#",
    "schema":   "https://schema.org/",
    "prov":     "http://www.w3.org/ns/prov#",
    "foaf":     "http://xmlns.com/foaf/0.1/",
    "dcterms":  "http://purl.org/dc/terms/",
    "xsd":      "http://www.w3.org/2001/XMLSchema#",
    "sh":       "http://www.w3.org/ns/shacl#",

    "_comment_keyword_aliases": "Friendly aliases for JSON-LD keywords so authors do not need to type @id/@type by hand.",
    "id":       "@id",
    "type":     "@type",
    "graph":    "@graph",
    "context":  "@context",
    "language": "@language",

    "_comment_label_terms": "Label aliasing — rdfs:label, skos:prefLabel, and schema:name all collapse to one canonical 'label' property at the wire level. This is the single most important normalisation in the schema: NO drift between systems on what 'the label' means. Default language is English; multi-lingual labels use @language.",
    "label":      {"@id": "rdfs:label",         "@language": "en"},
    "prefLabel":  {"@id": "skos:prefLabel",     "@language": "en"},
    "altLabel":   {"@id": "skos:altLabel",      "@language": "en", "@container": "@set"},
    "title":      {"@id": "schema:name",        "@language": "en"},
    "name":       {"@id": "schema:name",        "@language": "en"},

    "_comment_definition_terms": "skos:definition is canonical. dcterms:description aliases to it. schema:description aliases too. Anything that resembles a 'long-form definition' lands here.",
    "definition":  {"@id": "skos:definition",   "@language": "en"},
    "description": {"@id": "schema:description","@language": "en"},
    "comment":     {"@id": "rdfs:comment",      "@language": "en"},
    "summary":     {"@id": "schema:abstract",   "@language": "en"},

    "_comment_domain_types": "VisionFlow domain types map to W3C class IRIs where one exists. Authors write 'type: OntologyClass' and the canonical RDF emits 'a owl:Class'.",
    "OntologyClass":    {"@id": "owl:Class"},
    "OntologyProperty": {"@id": "owl:ObjectProperty"},
    "DataProperty":     {"@id": "owl:DatatypeProperty"},
    "AnnotationProperty": {"@id": "owl:AnnotationProperty"},
    "Axiom":            {"@id": "owl:Axiom"},
    "Restriction":      {"@id": "owl:Restriction"},
    "Page":             {"@id": "schema:WebPage"},
    "LinkedPage":       {"@id": "vc:LinkedPage"},
    "Person":           {"@id": "foaf:Person"},
    "Agent":            {"@id": "prov:Agent"},
    "AgentTelemetry":   {"@id": "vc:AgentTelemetry"},
    "Signature":        {"@id": "vc:Signature"},

    "_comment_class_axioms": "OWL 2 EL class axioms. subClassOf, equivalentClass, someValuesFrom, propertyChainAxiom. We deliberately do NOT alias allValuesFrom, complementOf, unionOf, disjointWith — they're outside EL and the validator rejects them with a citation to OWL 2 EL §3.",
    "subClassOf":           {"@id": "rdfs:subClassOf",         "@type": "@id"},
    "subPropertyOf":        {"@id": "rdfs:subPropertyOf",      "@type": "@id"},
    "equivalentClass":      {"@id": "owl:equivalentClass",     "@type": "@id"},
    "equivalentProperty":   {"@id": "owl:equivalentProperty",  "@type": "@id"},
    "someValuesFrom":       {"@id": "owl:someValuesFrom",      "@type": "@id"},
    "onProperty":           {"@id": "owl:onProperty",          "@type": "@id"},
    "propertyChainAxiom":   {"@id": "owl:propertyChainAxiom",  "@type": "@id", "@container": "@list"},
    "domain":               {"@id": "rdfs:domain",             "@type": "@id"},
    "range":                {"@id": "rdfs:range",              "@type": "@id"},
    "inverseOf":            {"@id": "owl:inverseOf",           "@type": "@id"},
    "transitiveProperty":   {"@id": "owl:TransitiveProperty"},
    "functionalProperty":   {"@id": "owl:FunctionalProperty"},
    "reflexiveProperty":    {"@id": "owl:ReflexiveProperty"},

    "_comment_visionflow_relations": "VisionFlow-specific object relations. These are predicates on the wire; they live under vc: because they have no perfect W3C analogue. bridgeTo connects the knowledge graph to the ontology graph (per ADR-08 §D2). hasPart / requires / enables / relatesTo are the relationship types catalogued in OwlClass V2's vec fields, now first-class predicates.",
    "bridgeTo":      {"@id": "vc:bridgeTo",      "@type": "@id"},
    "bridgeFrom":    {"@id": "vc:bridgeFrom",    "@type": "@id"},
    "hasPart":       {"@id": "vc:hasPart",      "@type": "@id"},
    "isPartOf":      {"@id": "vc:isPartOf",     "@type": "@id"},
    "requires":      {"@id": "vc:requires",     "@type": "@id"},
    "dependsOn":     {"@id": "vc:dependsOn",    "@type": "@id"},
    "enables":       {"@id": "vc:enables",      "@type": "@id"},
    "relatesTo":     {"@id": "vc:relatesTo",    "@type": "@id"},
    "definedIn":     {"@id": "vc:definedIn",    "@type": "@id"},
    "wikilinkTo":    {"@id": "vc:wikilinkTo",   "@type": "@id"},

    "_comment_provenance": "PROV-O is the canonical provenance vocabulary. Every JSON-LD block MUST carry wasAttributedTo + generatedAtTime. The pre-ingest validator rejects blocks missing either.",
    "wasAttributedTo": {"@id": "prov:wasAttributedTo",   "@type": "@id"},
    "wasDerivedFrom":  {"@id": "prov:wasDerivedFrom",    "@type": "@id"},
    "wasGeneratedBy":  {"@id": "prov:wasGeneratedBy",    "@type": "@id"},
    "generatedAtTime": {"@id": "prov:generatedAtTime",   "@type": "xsd:dateTime"},
    "invalidatedAt":   {"@id": "prov:invalidatedAtTime", "@type": "xsd:dateTime"},

    "_comment_quality_scores": "OwlClass V2's quality_score / authority_score / status / maturity fields, recast as vc: predicates. xsd:float for numerics, xsd:string for enums. Enum values constrained by SHACL-lite shapes in the validator.",
    "sourceDomain":   {"@id": "vc:sourceDomain"},
    "qualityScore":   {"@id": "vc:qualityScore",   "@type": "xsd:float"},
    "authorityScore": {"@id": "vc:authorityScore", "@type": "xsd:float"},
    "maturity":       {"@id": "vc:maturity"},
    "status":         {"@id": "vc:status"},
    "physicality":    {"@id": "vc:physicality"},
    "role":           {"@id": "vc:role"},
    "classType":      {"@id": "vc:classType"},

    "_comment_render_hints": "Visual layering hints consumed by Section 4 (Rendering). renderTier and ontologyTier travel as triples; the projection step in Section 8 surfaces them on TopologyNode.",
    "renderTier":     {"@id": "vc:renderTier",     "@type": "xsd:integer"},
    "ontologyTier":   {"@id": "vc:ontologyTier",   "@type": "xsd:integer"},
    "mass":           {"@id": "vc:mass",           "@type": "xsd:float"},

    "_comment_versioning": "Schema versioning lives on the document, not the context. schemaVersion is asserted on every Page/OntologyClass; parsers refuse documents whose schemaVersion mismatches the @context URL.",
    "schemaVersion":  {"@id": "vc:schemaVersion",  "@type": "xsd:integer"},
    "stub":           {"@id": "vc:stub",           "@type": "xsd:boolean"},
    "public":         {"@id": "vc:public",         "@type": "xsd:boolean"},

    "_comment_source_tracking": "Where did this assertion come from? source_file / file_sha1 / last_synced on OwlClass V2 become these. dcterms:source for the URL/path, vc:contentHash for the deterministic hash.",
    "source":         {"@id": "dcterms:source",    "@type": "@id"},
    "sourcePath":     {"@id": "vc:sourcePath"},
    "contentHash":    {"@id": "vc:contentHash"},
    "lastSynced":     {"@id": "vc:lastSynced",     "@type": "xsd:dateTime"},
    "created":        {"@id": "dcterms:created",   "@type": "xsd:dateTime"},
    "modified":       {"@id": "dcterms:modified",  "@type": "xsd:dateTime"},

    "_comment_signature": "Page-level Nostr signature. The signature itself is a NIP-23 event, not embedded in the markdown. signedBy carries the pubkey, signatureEvent carries the event ID, signatureNotBefore/After carry the validity window.",
    "signedBy":           {"@id": "vc:signedBy",            "@type": "@id"},
    "signatureEvent":     {"@id": "vc:signatureEvent"},
    "signatureNotBefore": {"@id": "vc:signatureNotBefore",  "@type": "xsd:dateTime"},
    "signatureNotAfter":  {"@id": "vc:signatureNotAfter",   "@type": "xsd:dateTime"},

    "_comment_agent_telemetry": "Agent telemetry under vcagent: IRIs. Each step carries a run_id and a step number. agent telemetry events land in the <urn:visionflow:graph:agent> named graph.",
    "runId":          {"@id": "vc:runId"},
    "step":           {"@id": "vc:step",           "@type": "xsd:integer"},
    "agentKind":      {"@id": "vc:agentKind"},
    "tool":           {"@id": "vc:tool"},
    "outcome":        {"@id": "vc:outcome"},
    "latencyMs":      {"@id": "vc:latencyMs",      "@type": "xsd:integer"},

    "_comment_dcterms_aliases": "Common dcterms predicates surfaced as friendly aliases.",
    "creator":        {"@id": "dcterms:creator",   "@type": "@id"},
    "license":        {"@id": "dcterms:license",   "@type": "@id"},
    "subject":        {"@id": "dcterms:subject",   "@container": "@set"},
    "tags":           {"@id": "schema:keywords",   "@container": "@set"},

    "_comment_collection_containers": "Common containers. @set is the default for unordered multi-value properties; @list is reserved for ordered constructs (propertyChainAxiom).",
    "parentClasses":  {"@id": "rdfs:subClassOf",   "@type": "@id", "@container": "@set"},
    "parentProperties": {"@id": "rdfs:subPropertyOf", "@type": "@id", "@container": "@set"}
  }
}
